{
  "name": "agent-cv",
  "version": "0.1.2",
  "description": "Generate technical CVs from your local project directories using AI",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "agent-cv": "dist/cli.js"
  },
  "files": [
    "dist/cli.js"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "build:npm": "bun run scripts/build-npm.ts",
    "build:binary": "bun build src/cli.ts --compile --outfile dist/agent-cv --minify",
    "postinstall": "lefthook install",
    "prepublishOnly": "bun run build:npm"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "bun-types": "1.3.11",
    "ink-testing-library": "^4.0.0",
    "lefthook": "^2.1.4",
    "react-devtools-core": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@agent-cv/core": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "@xstate/react": "^6.1.0",
    "commander": "^14.0.3",
    "ink": "^7.0.0",
    "react": "^19.2.4",
    "xstate": "^5.30.0",
    "zod": "^4.3.6"
  },
  "keywords": [
    "cv",
    "resume",
    "portfolio",
    "developer",
    "git",
    "ai",
    "cli"
  ],
  "license": "SEE LICENSE IN LICENSE FILE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-cv/agent-cv.git"
  },
  "homepage": "https://agent-cv.dev"
}
